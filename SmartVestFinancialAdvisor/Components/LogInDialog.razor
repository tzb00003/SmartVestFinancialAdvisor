@using System.ComponentModel.DataAnnotations
@using MudBlazor

<MudDialog MaxWidth="MaxWidth.ExtraSmall"
           FullWidth="true"
           CloseOnEscapeKey="true">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Lock" />
            Sign in
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form"
                 Model="_model"
                 Validation="OnValidationChanged"
                 Immediate="true">

            <MudTextField @bind-Value="_model.Email"
                          For="@(() => _model.Email)"
                          Label="Email"
                          Placeholder="you@example.com"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          Required="true"
                          RequiredError="Email is required"
                          Autofocus="true"
                          Autocomplete="email" />

            <MudTextField @bind-Value="_model.Password"
                          For="@(() => _model.Password)"
                          Label="Password"
                          Placeholder="Enter your password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          Required="true"
                          RequiredError="Password is required"
                          Autocomplete="current-password">
                <AdornmentEndContent>
                    <MudIconButton Size="Size.Small"
                                   Edge="Edge.End"
                                   Color="Color.Default"
                                   AriaLabel="@(_showPassword ? "Hide password" : "Show password")"
                                   Icon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                   OnClick="TogglePassword" />
                </AdornmentEndContent>
            </MudTextField>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                    @_error
                </MudAlert>
            }
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="Cancel"
                   Disabled="_isSubmitting">
            Cancel
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(!_isValid || _isSubmitting)"
                   Loading="_isSubmitting">
            Sign in
        </MudButton>
    </DialogActions>
</MudDialog>

<MudCheckBox T="bool"
             @bind-Value="_model.RememberMe"
             Label="New User"
             Dense="true"
             Class="mb-6, ml-2" />

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? _form;
    private bool _isValid;
    private bool _showPassword;
    private bool _isSubmitting;
    private string? _error;

    private readonly LoginModel _model = new();

    private void OnValidationChanged(MudForm form)
    {
        _isValid = form.IsValid;
    }

    private void TogglePassword() => _showPassword = !_showPassword;

    private async Task Submit()
    {
        if (_form is null)
            return;

        _error = null;

        await _form.Validate();
        if (!_form.IsValid)
            return;

        try
        {
            _isSubmitting = true;

            // TODO: Replace with your real authentication logic
            // Example:
            // var ok = await _authService.LoginAsync(_model.Email, _model.Password);
            // if (!ok) { _error = "Invalid email or password."; return; }

            // Simulate success result
            MudDialog.Close(DialogResult.Ok(new LoginResult
            {
                Email = _model.Email,
                RememberMe = _model.RememberMe,
                Success = true
            }));
        }
        catch (Exception ex)
        {
            _error = "An unexpected error occurred. Please try again.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    public sealed class LoginModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }

    public sealed class LoginResult
    {
        public string Email { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
        public bool Success { get; set; }
    }
}