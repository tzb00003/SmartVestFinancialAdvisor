@page "/financial-survey"
@using System.Globalization
@using MudBlazor
@using SmartVestFinancialAdvisor.Components.Models
@using SmartVestFinancialAdvisor.Components.ViewModels
@inject FinancialSurveyViewModel vm
@inject NavigationManager Nav
@implements IDisposable

<MudPaper Class="mx-auto my-6 p-6" Elevation="2" Style="max-width: 980px;">
    <MudStack Spacing="2">

        <MudText Typo="Typo.h5">Financial Survey</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Please fill in all required fields. Financial items are optional.
        </MudText>

        <!-- ================= REQUIRED SURVEY FORM ================= -->
        <MudForm @ref="_form"
                 Model="vm.Model"
                 OnValidationChanged="OnValidationChanged"
                 Immediate="true">

            <MudGrid Spacing="2">

                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.MonthlyIncome"
                                     Label="Monthly Income (Gross)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Required
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.Savings"
                                     Label="Total Savings Value of All Types"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Required
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.Debt"
                                     Label="Debt Payments (Monthly)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Required
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.MonthlyExpense"
                                     Label="Monthly Living Expenses"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Required
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="RiskLevel"
                               @bind-Value="vm.Model.RiskLevel"
                               Label="Desired Investment Risk Level"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="RiskLevel.Low">Low</MudSelectItem>
                        <MudSelectItem Value="RiskLevel.Med">Medium</MudSelectItem>
                        <MudSelectItem Value="RiskLevel.High">High</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField T="int?"
                                     @bind-Value="vm.Model.Age"
                                     Label="Age"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Required
                                     Min="18"
                                     Max="120" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="string"
                               @bind-Value="vm.Model.State"
                               Label="State"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Required>
                        @foreach (var s in vm.States)
                        {
                            <MudSelectItem Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

            </MudGrid>
        </MudForm>

        <!-- ================= OPTIONAL FINANCIAL ITEMS ================= -->
        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle1">Financial Items (Optional)</MudText>
        <MudAlert Severity="Severity.Info" Dense="true">
            Add debts or savings to improve accuracy. This is optional but your score will be lower if you cannot provide a breakdown of the assets above. This helps us give you the
            best reccomendations we possibly can.
        </MudAlert>

        <!-- ---------- ADD ITEM TABS ---------- -->
        <MudTabs Rounded="true" Elevation="1">

            <!-- ADD DEBT -->
            <MudTabPanel Text="Add Debt">
                <MudGrid Spacing="2">

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_newDebt.Label"
                                      Label="Debt Name"
                                      Placeholder="Auto Loan, Credit Card"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?"
                                         @bind-Value="_newDebt.Amount"
                                         Label="Remaining Balance"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Format="C0" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?"
                                         @bind-Value="_newDebt.MonthlyPayment"
                                         Label="Monthly Payment"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Format="C0" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?"
                                         @bind-Value="_newDebt.InterestRate"
                                         Label="Interest Rate (%)"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Converter="PercentAsNumberConverter" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddDebt">
                            Add Debt
                        </MudButton>
                    </MudItem>

                </MudGrid>
            </MudTabPanel>

            <!-- ADD SAVINGS -->
            <MudTabPanel Text="Add Savings">
                <MudGrid Spacing="2">

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_newSavings.Label"
                                      Label="Account Name"
                                      Placeholder="Savings, Brokerage, 401(k)"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?"
                                         @bind-Value="_newSavings.Amount"
                                         Label="Account Value"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Format="C0" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudCheckBox T="bool"
                                     @bind-Checked="_newSavings.IsRetirement"
                                     Label="Retirement Account" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddSavings">
                            Add Savings
                        </MudButton>
                    </MudItem>

                </MudGrid>
            </MudTabPanel>

        </MudTabs>

        <!-- ================= ITEM CARDS ================= -->
        @if (vm.Model.Items.Any())
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle2">Added Items</MudText>

            <MudGrid Spacing="2">
                @foreach (var item in vm.Model.Items)
                {
                    <MudItem xs="12" md="6">
                        <MudCard Elevation="2">
                            <MudCardContent>
                                <MudText Typo="Typo.h6">@item.Label</MudText>
                                <MudText Typo="Typo.body2">
                                    Amount: @item.Amount?.ToString("C0")
                                </MudText>

                                @if (item.IsDebt)
                                {
                                    <MudText Typo="Typo.body2">
                                        Payment: @item.MonthlyPayment?.ToString("C0")
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        Interest: @(item.InterestRate * 100m ?? 0m)%
                                    </MudText>
                                }
                                else if (item.IsRetirement)
                                {
                                    <MudChip t="string" Color="Color.Primary" Variant="Variant.Outlined">
                                        Retirement Account
                                    </MudChip>
                                }
                            </MudCardContent>

                            <MudCardActions Class="justify-end">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => vm.RemoveItem(item))" />
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

        <!-- ================= ACTIONS ================= -->
        <MudStack Direction="Row" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Text" OnClick="Reset">
                Reset
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(!(_form?.IsValid ?? false) || vm.IsSubmitting)"
                       Loading="vm.IsSubmitting"
                       OnClick="Submit">
                Submit
            </MudButton>
        </MudStack>

    </MudStack>
</MudPaper>

@code {
    private MudForm? _form;
    private readonly CultureInfo Culture = CultureInfo.CurrentCulture;

    private FinancialItem _newDebt = new() { IsDebt = true };
    private FinancialItem _newSavings = new();

    private void OnValidationChanged(bool valid) => vm.IsValid = valid;

    private Converter<decimal?> PercentAsNumberConverter => new()
    {
        GetFunc = input =>
            decimal.TryParse(input, NumberStyles.Number, Culture, out var v) ? v / 100m : null,
        SetFunc = value =>
            value is null ? null : (value.Value * 100m).ToString("0.###", Culture)
    };

    protected override void OnInitialized()
        => vm.StateChanged += StateHasChanged;

    private void AddDebt()
    {
        if (string.IsNullOrWhiteSpace(_newDebt.Label)) return;
        vm.Model.Items.Add(_newDebt);
        _newDebt = new FinancialItem { IsDebt = true };
    }

    private void AddSavings()
    {
        if (string.IsNullOrWhiteSpace(_newSavings.Label)) return;
        vm.Model.Items.Add(_newSavings);
        _newSavings = new FinancialItem();
    }

    private async Task Submit()
    {
        await _form!.Validate();
        if (!_form.IsValid) return;

        vm.IsSubmitting = true;
        await vm.SubmitAsync();
        vm.IsSubmitting = false;

        Nav.NavigateTo("/home#analysis", replace: true);
    }

    private void Reset()
    {
        vm.Reset();
        _form?.ResetValidation();
        vm.IsValid = false;
    }

    public void Dispose()
        => vm.StateChanged -= StateHasChanged;
}