@page "/financial-survey"
@using System.Globalization
@using MudBlazor
@using SmartVestFinancialAdvisor.Components.Models
@using SmartVestFinancialAdvisor.Components.ViewModels
@inject FinancialSurveyViewModel vm
@inject NavigationManager Nav
@implements IDisposable

<MudPaper Class="mx-auto my-6 p-6" Elevation="2" Style="max-width: 980px;">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h5" Class="mb-1">
            Financial Survey
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Please fill in all required fields. Your responses help us understand your financial profile.
        </MudText>

        <!-- CHANGED: Use OnValidationChanged (bool) -->
        <MudForm @ref="_form"
                 Model="vm.Model"
                 OnValidationChanged="OnValidationChanged"
                 Immediate="true">

            <MudGrid Spacing="2">
                <!-- Monthly Income -->
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.MonthlyIncome"
                                     For="@(() => vm.Model.MonthlyIncome)"
                                     Label="Monthly Income (Gross)"
                                     Placeholder="e.g., 7,500"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0"
                                     Step="100"
                                     Required="true"
                                     RequiredError="Monthly income is required"
                                     InputMode="InputMode.numeric"
                                     DebounceInterval="150"
                                     HideSpinButtons="true"
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture">
                        <AdornmentStartContent>
                            <MudText>$</MudText>
                        </AdornmentStartContent>
                        <HelperText>Gross income before taxes and deductions (per month).</HelperText>
                    </MudNumericField>
                </MudItem>

                <!-- Savings -->
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.Savings"
                                     For="@(() => vm.Model.Savings)"
                                     Label="Savings (Liquid)"
                                     Placeholder="e.g., 25,000"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0"
                                     Step="500"
                                     Required="true"
                                     RequiredError="Savings is required"
                                     InputMode="InputMode.numeric"
                                     DebounceInterval="150"
                                     HideSpinButtons="true"
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture">
                        <AdornmentStartContent>
                            <MudText>$</MudText>
                        </AdornmentStartContent>
                        <HelperText>Cash &amp; equivalents (e.g., checking, savings, money market).</HelperText>
                    </MudNumericField>
                </MudItem>

                <!-- Total Debt Payments (Monthly) -->
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.Debt"
                                     For="@(() => vm.Model.Debt)"
                                     Label="Debt Payments (Monthly)"
                                     Placeholder="e.g., 1,200"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0"
                                     Step="50"
                                     Required="true"
                                     RequiredError="Total monthly debt payments are required"
                                     InputMode="InputMode.numeric"
                                     DebounceInterval="150"
                                     HideSpinButtons="true"
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture">
                        <AdornmentStartContent>
                            <MudText>$</MudText>
                        </AdornmentStartContent>
                        <HelperText>Sum of monthly payments for liabilities.</HelperText>
                    </MudNumericField>
                </MudItem>

                <!-- Monthly Living Expenses -->
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?"
                                     @bind-Value="vm.Model.MonthlyExpense"
                                     For="@(() => vm.Model.MonthlyExpense)"
                                     Label="Monthly Living Expenses"
                                     Placeholder="e.g., 2,800"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0"
                                     Step="50"
                                     Required="true"
                                     RequiredError="Monthly living expenses are required"
                                     InputMode="InputMode.numeric"
                                     DebounceInterval="150"
                                     HideSpinButtons="true"
                                     Format="C0"
                                     Culture="@CultureInfo.CurrentCulture">
                        <AdornmentStartContent>
                            <MudText>$</MudText>
                        </AdornmentStartContent>
                        <HelperText>Housing, utilities, food, childcare, insurance, etc.</HelperText>
                    </MudNumericField>
                </MudItem>

                <!-- Risk Level -->
                <MudItem xs="12" md="6">
                    <MudSelect T="RiskLevel"
                               @bind-Value="vm.Model.RiskLevel"
                               For="@(() => vm.Model.RiskLevel)"
                               Label="Risk Level"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="RiskLevel" Value="RiskLevel.Low">Low</MudSelectItem>
                        <MudSelectItem T="RiskLevel" Value="RiskLevel.Med">Med</MudSelectItem>
                        <MudSelectItem T="RiskLevel" Value="RiskLevel.High">High</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Age -->
                <MudItem xs="12" md="6">
                    <MudNumericField T="int?"
                                     @bind-Value="vm.Model.Age"
                                     For="@(() => vm.Model.Age)"
                                     Label="Age"
                                     Placeholder="e.g., 35"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="18"
                                     Max="120"
                                     Step="1"
                                     Required="true"
                                     RequiredError="Age is required"
                                     InputMode="InputMode.numeric"
                                     DebounceInterval="150"
                                     HideSpinButtons="true" />
                </MudItem>

                <!-- State -->
                <MudItem xs="12" md="6">
                    <MudSelect T="string"
                               @bind-Value="vm.Model.State"
                               For="@(() => vm.Model.State)"
                               Label="State"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true"
                               Required="true"
                               RequiredError="State is required"
                               SearchFunc="@((string text) => Task.FromResult(vm.States.Where(s => s.Contains(text, StringComparison.OrdinalIgnoreCase)).ToList()))"
                               ToStringFunc="@(s => s)">
                        @foreach (var s in vm.States)
                        {
                            <MudSelectItem Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            <!-- Financial Items -->
            <MudStack Spacing="1">
                <MudText Typo="Typo.subtitle1">Financial Items</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Add assets and liabilities. Use interest rate as a decimal (e.g., 0.05 for 5%).
                </MudText>

                <MudTable Items="vm.Model.Items" Dense="true" Elevation="0" Hover="false" Bordered="true" Striped="false">
                    <HeaderContent>
                        <MudTh>Label</MudTh>
                        <MudTh class="text-right">Amount</MudTh>
                        <MudTh class="text-right">Monthly Payment</MudTh>
                        <MudTh class="text-right">Interest Rate</MudTh>
                        <MudTh class="text-center">Is Debt</MudTh>
                        <MudTh class="text-center">Is Retirement</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="Label" Class="w-40">
                            <MudTextField @bind-Value="@context.Label"
                                          Placeholder="e.g., 401(k), Auto Loan"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          Required="true"
                                          RequiredError="Label is required" />
                        </MudTd>

                        <MudTd DataLabel="Amount" Class="w-32">
                            <MudNumericField T="decimal?"
                                             @bind-Value="@context.Amount"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="0"
                                             Step="100"
                                             InputMode="InputMode.numeric"
                                             HideSpinButtons="true"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                             Immediate="true"
                                             Format="C0"
                                             Culture="@CultureInfo.CurrentCulture">
                                <HelperText>Current balance/value</HelperText>
                            </MudNumericField>
                        </MudTd>

                        <MudTd DataLabel="Monthly Payment" Class="w-32">
                            <MudNumericField T="decimal?"
                                             @bind-Value="@context.MonthlyPayment"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="0"
                                             Step="25"
                                             InputMode="InputMode.numeric"
                                             HideSpinButtons="true"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.Payments"
                                             Immediate="true"
                                             Format="C0"
                                             Culture="@CultureInfo.CurrentCulture">
                                <HelperText>Payment per month</HelperText>
                            </MudNumericField>
                        </MudTd>

                        <!-- Interest Rate with converter (user enters 5.5 meaning 5.5%) -->
                        <MudTd DataLabel="Interest Rate" Class="w-28">
                            <MudNumericField T="decimal?"
                                             @bind-Value="@context.InterestRate"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="0"
                                             Max="100"
                                             Step="0.1m"
                                             Placeholder="5.5"
                                             InputMode="InputMode.numeric"
                                             HideSpinButtons="true"
                                             Immediate="true"
                                             Converter="PercentAsNumberConverter"
                                             Culture="@Culture">
                                <AdornmentEndContent>
                                    <MudText>%</MudText>
                                </AdornmentEndContent>
                                <HelperText>Enter percent (e.g., 5.5 for 5.5%).</HelperText>
                            </MudNumericField>
                        </MudTd>

                        <MudTd DataLabel="Is Debt" Class="text-center">
                            <MudCheckBox T="bool"
                                         @bind-Checked="@context.IsDebt"
                                         Immediate="true"
                                         For="@(() => context.IsDebt)"
                                         AriaLabel="Mark as debt" />
                        </MudTd>

                        <MudTd DataLabel="Is Retirement" Class="text-center">
                            <MudCheckBox T="bool"
                                         @bind-Checked="@context.IsRetirement"
                                         Disabled="@context.IsDebt"
                                         Immediate="true"
                                         For="@(() => context.IsRetirement)"
                                         AriaLabel="Mark as retirement" />
                        </MudTd>

                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Disabled="vm.IsSubmitting"
                                           OnClick="@(() => vm.RemoveItem(context))"
                                           AriaLabel="Remove item" />
                        </MudTd>
                    </RowTemplate>

                    <FooterContent>
                        <MudTd ColSpan="7">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Disabled="vm.IsSubmitting"
                                       OnClick="vm.AddItem">
                                Add Item
                            </MudButton>
                        </MudTd>
                    </FooterContent>
                </MudTable>

                <MudHidden Breakpoint="Breakpoint.SmAndUp">
                    <div class="mt-2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="vm.IsSubmitting"
                                   OnClick="vm.AddItem"
                                   FullWidth="true">
                            Add Item
                        </MudButton>
                    </div>
                </MudHidden>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(vm.ServerError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                    @vm.ServerError
                </MudAlert>
            }

            <MudStack Direction="Row" Spacing="2" Class="mt-4">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           OnClick="Reset"
                           Disabled="vm.IsSubmitting">
                    Reset
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="Submit"
                           Disabled="@(!(_form?.IsValid ?? false) || vm.IsSubmitting)"
                           Loading="vm.IsSubmitting">
                    Submit
                </MudButton>
            </MudStack>
        </MudForm>
    </MudStack>
</MudPaper>

@code {
    private MudForm? _form;

    // Use the current culture for parsing/formatting numbers in the interest converter
    private readonly CultureInfo Culture = CultureInfo.CurrentCulture;

    // ✅ Correct handler: receives 'bool valid'
    private void OnValidationChanged(bool valid) => vm.IsValid = valid;

    // Converter: shows the model's decimal (0..1) as a percent number (0..100) to the user,
    // and converts the user's percent input back to decimal for the model.
    private Converter<decimal?> PercentAsNumberConverter => new()
    {
        // User types a number (e.g., "5.5") -> store as decimal fraction (0.055)
        GetFunc = input =>
        {
            if (string.IsNullOrWhiteSpace(input))
                return (decimal?)null;

            if (decimal.TryParse(input, NumberStyles.Number, Culture, out var percentValue))
                return percentValue / 100m;

            return (decimal?)null;
        },

        // Model has decimal fraction (e.g., 0.055) -> show "5.5" to the user
        SetFunc = modelValue =>
        {
            if (modelValue is null)
                return null;

            var percent = modelValue.Value * 100m;
            return percent.ToString("0.###", Culture);
        }
    };

    protected override void OnInitialized()
    {
        vm.StateChanged += StateHasChanged;
    }

    private async Task Submit()
    {
        vm.ServerError = null;
        vm.Submitted = false;

        if (_form is null)
            return;

        await _form.Validate();
        vm.IsValid = _form.IsValid;

        if (!(_form.IsValid))
            return;

        try
        {
            vm.IsSubmitting = true;

            // This should populate vm.AdvisorResult internally (BuildResult)
            await vm.SubmitAsync();

            vm.Submitted = true;
        }
        catch (Exception ex)
        {
            var details = ex.InnerException is not null
                ? $"{ex.Message} | Inner: {ex.InnerException.Message}"
                : ex.Message;

            vm.ServerError = $"Submission failed: {details}";
            return; // don't continue to navigate
        }
        finally
        {
            // Turn off loading *before* navigating away to avoid post-nav state events
            vm.IsSubmitting = false;
        }

        // IMPORTANT: detach BEFORE we navigate to avoid 'renderer disposed' crashes
        vm.StateChanged -= StateHasChanged;

        // If you removed the success banner on Home, you can drop '?submitted=1'
        Nav.NavigateTo("/home#analysis", replace: true);
    }

    private void Reset()
    {
        vm.Reset();
        _form?.ResetValidation();

        // Reflect reset validation into button state
        vm.IsValid = false;
    }

    public void Dispose()
    {
        vm.StateChanged -= StateHasChanged;
    }
}