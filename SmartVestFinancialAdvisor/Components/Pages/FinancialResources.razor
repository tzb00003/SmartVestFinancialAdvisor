@page "/financial-resources"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h4" GutterBottom="true">
        Financial Resources
    </MudText>

    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Explore common financial investments, how they work, and when they may make sense.
    </MudText>

    <MudTabs Rounded="true" Elevation="1">

        <!-- CASH & SHORT-TERM -->
        <MudTabPanel Text="Cash & Short‑Term">
            <MudExpansionPanels Multiple="true">

                <MudExpansionPanel Text="High‑Yield Savings Account (HYSA)">
                    <MudText><b>What it is:</b> A savings account that pays higher interest than a traditional bank account.</MudText>
                    <MudText><b>Why people use it:</b> To store emergency funds or money needed in the near future.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Very safe</MudListItem>
                        <MudListItem T="string">Easy access to cash</MudListItem>
                        <MudListItem T="string">Earns interest</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Returns may not keep up with inflation</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Emergency funds and short‑term goals.</MudText>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Treasury Bills (3–6 Months)">
                    <MudText><b>What it is:</b> Short‑term loans you give to the U.S. government.</MudText>
                    <MudText><b>Why people use it:</b> A safe place to park cash for a few months.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Backed by the U.S. government</MudListItem>
                        <MudListItem T="string">Predictable return</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Money is locked up until maturity</MudListItem>
                        <MudListItem T="string">Lower returns than long‑term investments</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Short‑term cash with minimal risk.</MudText>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudTabPanel>

        <!-- BONDS -->
        <MudTabPanel Text="Bonds">
            <MudExpansionPanels Multiple="true">

                <MudExpansionPanel Text="Investment‑Grade Bond Fund">
                    <MudText><b>What it is:</b> A fund that holds many high‑quality bonds.</MudText>
                    <MudText><b>Why people use it:</b> To add stability and income to a portfolio.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Less volatile than stocks</MudListItem>
                        <MudListItem T="string">Regular income</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Can lose value when interest rates rise</MudListItem>
                        <MudListItem T="string">Lower long‑term growth than stocks</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Balancing risk in long‑term portfolios.</MudText>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Inflation‑Protected Bonds (TIPS)">
                    <MudText><b>What it is:</b> Bonds whose value adjusts with inflation.</MudText>
                    <MudText><b>Why people use it:</b> To protect purchasing power.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Helps offset inflation risk</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Lower returns when inflation is low</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Conservative investors worried about inflation.</MudText>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudTabPanel>

        <!-- STOCKS -->
        <MudTabPanel Text="Stocks">
            <MudExpansionPanels Multiple="true">

                <MudExpansionPanel Text="Total U.S. Stock Market Index Fund">
                    <MudText><b>What it is:</b> A fund that owns thousands of U.S. companies.</MudText>
                    <MudText><b>Why people use it:</b> Broad exposure and long‑term growth.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Highly diversified</MudListItem>
                        <MudListItem T="string">Low cost</MudListItem>
                        <MudListItem T="string">Strong long‑term growth potential</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Can drop significantly during market downturns</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Long‑term investors comfortable with volatility.</MudText>
                </MudExpansionPanel>

                <MudExpansionPanel Text="International Stock Index Fund">
                    <MudText><b>What it is:</b> A fund investing in companies outside the U.S.</MudText>
                    <MudText><b>Why people use it:</b> Geographic diversification.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Reduces reliance on one country</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Currency and political risk</MudListItem>
                        <MudListItem T="string">May lag U.S. markets for long periods</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Diversifying long‑term portfolios.</MudText>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudTabPanel>

        <!-- REAL ASSETS -->
        <MudTabPanel Text="Real Assets & Hedges">
            <MudExpansionPanels Multiple="true">

                <MudExpansionPanel Text="Real Estate Investment Trusts (REITs)">
                    <MudText><b>What it is:</b> Companies that own income‑producing real estate.</MudText>
                    <MudText><b>Why people use it:</b> Income and diversification.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Regular income</MudListItem>
                        <MudListItem T="string">Real estate exposure without owning property</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Sensitive to interest rates</MudListItem>
                        <MudListItem T="string">Can be volatile</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Income‑focused portfolios.</MudText>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Commodities Basket">
                    <MudText><b>What it is:</b> A collection of raw materials like oil, metals, or agriculture.</MudText>
                    <MudText><b>Why people use it:</b> Inflation protection and diversification.</MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Pros:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">May perform well during inflation</MudListItem>
                    </MudList>
                    <MudText><b>Cons:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Highly volatile</MudListItem>
                        <MudListItem T="string">No income</MudListItem>
                    </MudList>
                    <MudText><b>Best for:</b> Small diversification positions only.</MudText>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudTabPanel>
        <MudTabPanel Text="Extra Financial Information">
            <MudExpansionPanels Multiple="true">

                <MudExpansionPanel Text="Emergency Funds: Why They Matter">
                    <MudText>
                        <b>What it is:</b> An emergency fund is cash set aside for unexpected expenses
                        like medical bills, job loss, or urgent repairs.
                    </MudText>
                    <MudText>
                        <b>Why it’s important:</b> It helps you avoid high‑interest debt and prevents
                        you from selling investments at the wrong time.
                    </MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>How much should you save?</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">3–6 months of essential expenses is common</MudListItem>
                        <MudListItem T="string">More if income is unpredictable</MudListItem>
                        <MudListItem T="string">Less if job security is high and costs are low</MudListItem>
                    </MudList>
                    <MudText>
                        <b>Best place to keep it:</b> High‑yield savings accounts or short‑term Treasuries.
                    </MudText>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Stocks vs Bonds: How They Work Together">
                    <MudText>
                        <b>Stocks:</b> Represent ownership in companies and offer the highest long‑term
                        growth, but prices can swing widely.
                    </MudText>
                    <MudText>
                        <b>Bonds:</b> Are loans that pay interest and tend to be more stable, but grow more slowly.
                    </MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Why mix them?</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Stocks drive growth</MudListItem>
                        <MudListItem T="string">Bonds reduce volatility</MudListItem>
                        <MudListItem T="string">Together they smooth the ride over time</MudListItem>
                    </MudList>
                    <MudText>
                        The right balance depends on your time horizon and comfort with risk.
                    </MudText>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Diversification: Avoiding All‑or‑Nothing Risk">
                    <MudText>
                        <b>What it means:</b> Spreading your money across different investments instead
                        of relying on a single one.
                    </MudText>
                    <MudText>
                        <b>Why it helps:</b> When one investment struggles, others may perform better.
                    </MudText>
                    <MudDivider Class="my-2" />
                    <MudList T="string">
                        <MudListItem T="string">Different asset types behave differently</MudListItem>
                        <MudListItem T="string">Reduces the impact of major losses</MudListItem>
                        <MudListItem T="string">Encourages long‑term discipline</MudListItem>
                    </MudList>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Time Horizon & Compounding">
                    <MudText>
                        <b>Time horizon:</b> How long you plan to invest before needing the money.
                    </MudText>
                    <MudText>
                        <b>Compounding:</b> Your returns earn returns over time, causing growth to accelerate.
                    </MudText>
                    <MudDivider Class="my-2" />
                    <MudText><b>Key takeaways:</b></MudText>
                    <MudList T="string">
                        <MudListItem T="string">Longer timelines allow more investment risk</MudListItem>
                        <MudListItem T="string">Small contributions grow significantly over time</MudListItem>
                        <MudListItem T="string">Staying invested matters more than timing the market</MudListItem>
                    </MudList>
                </MudExpansionPanel>

                <MudExpansionPanel Text="Rebalancing & Staying Disciplined">
                    <MudText>
                        <b>Rebalancing:</b> Adjusting your portfolio to maintain your intended mix of investments.
                    </MudText>
                    <MudText>
                        <b>Why it matters:</b> It keeps risk in check and prevents emotional decision‑making.
                    </MudText>
                    <MudDivider Class="my-2" />
                    <MudList T="string">
                        <MudListItem T="string">Sell assets that have grown too large</MudListItem>
                        <MudListItem T="string">Buy assets that have fallen behind</MudListItem>
                        <MudListItem T="string">Rebalance periodically, not constantly</MudListItem>
                    </MudList>
                    <MudText>
                        Good investing is often more about behavior than choosing the “perfect” investment.
                    </MudText>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudTabPanel>
    </MudTabs>

    <MudGrid Class="mt-6 mb-5">
        <MudItem xs="12" Class="d-flex justify-center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/home">
                Return to Home
            </MudButton>
        </MudItem>
    </MudGrid>

</MudContainer>