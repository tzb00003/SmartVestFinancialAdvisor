@page "/home"
@page "/"

@using MudBlazor
@using System.Linq
@using SmartVestFinancialAdvisor.Components
@using SmartVestFinancialAdvisor.Components.ViewModels
@using SmartVestFinancialAdvisor.Components.Models
@using SmartVestFinancialAdvisor.Components.Services

@inject FinancialSurveyViewModel vm
@inject IAuthenticationService AuthService
@inject IRecommendationCatalog Catalog
@inject NavigationManager Nav
@inject IDialogService DialogService

@implements IDisposable

<PageTitle>Home</PageTitle>

<MudGrid Spacing="3">

    <!-- Header -->
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudStack Direction="Row"
                      AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween">

                <div>
                    <MudText Typo="Typo.h2"
                             GutterBottom
                             Color="Color.Dark">
                        Welcome to SmartVest Financial Advisor
                    </MudText>

                    @if (AuthService.IsLoggedIn)
                    {
                        <MudText Typo="Typo.body1"
                                 Color="Color.Secondary">
                            Logged in as: <strong>@AuthService.CurrentEmail</strong>
                        </MudText>
                    }

                    <MudText Typo="Typo.body1">
                        This application is designed to help you manage your finances effectively
                        and make informed investment decisions.
                    </MudText>
                </div>

                @if (AuthService.IsLoggedIn)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               OnClick="LogoutAsync">
                        Logout
                    </MudButton>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    @if (!AuthService.IsLoggedIn)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-6 d-flex flex-column align-center justify-center"
            Style="text-align:center; border: 2px dashed var(--mud-palette-warning);">

                <MudIcon Icon="@Icons.Material.Filled.Lock"
                Size="Size.Large"
                Color="Color.Warning" />

                <MudText Typo="Typo.h5" Class="mt-2">
                    Authentication Required
                </MudText>

                <MudText Typo="Typo.body2" Class="mt-1">
                    Please log in or create an account to access the survey and view your financial analysis.
                </MudText>

                <MudButton Class="mt-3"
                Variant="Variant.Filled"
                Color="Color.Primary"
                OnClick="ShowLoginDialog">
                    Sign In / Register
                </MudButton>
            </MudPaper>
        </MudItem>
    }
    else if (_isLoading)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-6 d-flex justify-center">
                <MudProgressCircular Indeterminate
                Color="Color.Primary"
                Size="Size.Large" />
            </MudPaper>
        </MudItem>
    }
    else if (Recommendations.Count == 0)
    {
        <MudItem xs="12">
            <MudPaper Class="pa-6 d-flex flex-column align-center justify-center"
            Style="text-align:center;">

                <MudIcon Icon="@Icons.Material.Filled.Assessment"
                Size="Size.Large"
                Color="Color.Primary" />

                <MudText Typo="Typo.h5" Class="mt-2">
                    No survey or results
                </MudText>

                <MudText Typo="Typo.body2" Class="mt-1">
                    You haven't completed the financial survey yet.
                </MudText>

                <MudButton Class="mt-3"
                Variant="Variant.Filled"
                Color="Color.Primary"
                Href="/financial-survey">
                    Start the survey
                </MudButton>
            </MudPaper>
        </MudItem>
    }
    else
    {
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <FinancialAnalysisPanel Result="vm.AdvisorResult" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4"
                Style="background-color: #f2f2f2;">
                    <MudStack Spacing="2">

                    <MudText Typo="Typo.h6">
                        Financial Portfolio
                    </MudText>

                    <MudGrid Spacing="3">
                        @foreach (var rec in VisibleRecommendations)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Class="pa-4 d-flex flex-column"
                                          Elevation="1"
                                          Style="height:100%; background-color:#fff;">

                                    <MudStack Spacing="1" Style="flex-grow:1">

                                        <MudText Typo="Typo.subtitle1">
                                            <b>@rec.Type</b>
                                        </MudText>

                                        <MudText Typo="Typo.body2">
                                            <b>Risk:</b> @rec.Risk
                                        </MudText>

                                        <MudText Typo="Typo.body2">
                                            <b>Recommendation:</b> @rec.RecDisplay
                                        </MudText>

                                        <!-- Push expandable content to bottom -->
                                        <div style="margin-top:auto">
                                            <MudExpansionPanel Dense DisableRipple>
                                                <TitleContent>
                                                    <MudText Typo="Typo.body2">
                                                        <b>More information</b>
                                                    </MudText>
                                                </TitleContent>
                                                <ChildContent>
                                                    <MudText Typo="Typo.body2">
                                                        @rec.Info
                                                    </MudText>
                                                </ChildContent>
                                            </MudExpansionPanel>
                                        </div>

                                    </MudStack>

                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>


                </MudStack>
            </MudPaper>
        </MudItem>
        @if (CanShowMore)
        {
            <MudGrid Class="mt-4">
                <MudItem xs="12"  Class="d-flex justify-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="GenerateMore">
                        Show more
                    </MudButton>
                </MudItem>
            </MudGrid>
        }
    }

    <!-- Quick Actions -->
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">
                Quick Actions
            </MudText>

            <div class="d-flex mt-2"
                 style="gap:12px; flex-wrap:wrap;">

                @if (AuthService.IsLoggedIn)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Href="/financial-survey">
                        Take / Retake Survey
                    </MudButton>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           Href="/financial-resources">
                    Financial Resources
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           Href="/help">
                    Help
                </MudButton>

            </div>
        </MudPaper>
    </MudItem>

</MudGrid>

@code
{
    private const int PageSize = 4;

    private bool _isLoading = true;
    private List<Recommendation> Recommendations = new();
    private int _visibleCount = PageSize;

    private IEnumerable<Recommendation> VisibleRecommendations =>
        Recommendations.Take(_visibleCount);

    private bool CanShowMore =>
        Recommendations.Count > _visibleCount;

    protected override async Task OnInitializedAsync()
    {
        vm.StateChanged += VmOnStateChanged;
        AuthService.OnStateChanged += AuthOnStateChanged;

        if (AuthService.IsLoggedIn)
            await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        StateHasChanged();

        await vm.LoadUserResultAsync();
        RefreshRecommendations();

        _isLoading = false;
        StateHasChanged();
    }

    private async void AuthOnStateChanged()
    {
        if (AuthService.IsLoggedIn)
            await LoadAsync();
        else
            ResetPage();

        InvokeAsync(StateHasChanged);
    }

    private void VmOnStateChanged()
    {
        RefreshRecommendations();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshRecommendations()
    {
        Recommendations = vm.AdvisorResult is { } r
            ? Catalog.For(r).ToList()
            : new();

        _visibleCount = PageSize;
    }

    private void GenerateMore()
    {
        _visibleCount = Math.Min(
            _visibleCount + PageSize,
            Recommendations.Count
        );
    }

    private async Task ShowLoginDialog()
    {
        var dialog = await DialogService.ShowAsync<LogInDialog>();

        if (!(await dialog.Result).Canceled)
            Nav.NavigateTo("/");
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        ResetPage();
        Nav.NavigateTo("/");
    }

    private void ResetPage()
    {
        _isLoading = true;
        Recommendations.Clear();
        vm.Reset();
    }

    public void Dispose()
    {
        vm.StateChanged -= VmOnStateChanged;
        AuthService.OnStateChanged -= AuthOnStateChanged;
    }
}