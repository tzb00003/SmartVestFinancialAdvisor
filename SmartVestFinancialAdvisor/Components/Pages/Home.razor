@page "/"
@page "/home"
@using MudBlazor
@using System.Collections.Generic
@using System.Linq
@using SmartVestFinancialAdvisor.Components
@inject IDialogService DialogService


<PageTitle>Home</PageTitle>
<MudGrid Spacing="3">
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h2" GutterBottom="true" Color="Color.Dark">Welcome to SmartVest Financial Advisor</MudText>
            <MudText Typo="Typo.body1">
                This application is designed to help you manage your finances effectively and make informed investment decisions.
            </MudText>
        </MudPaper>
    </MudItem>

    <!-- Top summary fields -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Style="background-color: #f2f2f2;">
            <MudText Typo="Typo.h6">Financial Portfolio</MudText>
            <MudDataGrid Items="@Suggestions.Take(4)" Class="grid-with-borders">
                <Columns>
                    <PropertyColumn Property="x => x.type" Title="Investment Type" />
                    <PropertyColumn Property="x => x.risk" Title="Risk Level"/>
                    <PropertyColumn Property="x => x.rec" Title="Recommendation Level"/>
                    <PropertyColumn Property="x => x.info" Title="More Information"/>
                </Columns>
            </MudDataGrid>
        </MudPaper>

    </MudItem>


    <!-- Full width quick actions -->
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">Quick Actions</MudText>
            <div class="d-flex mt-2" style="gap:12px;flex-wrap:wrap;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/financial-survey" Disabled="false">Take Financial Survey</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/resources" Disabled="false">Financial Resources</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Href="/help" Disabled="false">Help</MudButton>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>
