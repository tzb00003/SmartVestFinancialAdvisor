@inherits LayoutComponentBase
@using MudBlazor
@inject IDialogService DialogService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

<MudThemeProvider />
<MudSnackbarProvider />
<MudDialogProvider />

<MudLayout>
    <MudAppBar>
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="DrawerToggle" />
        
        <MudSpacer />
         @*Login and Signup buttons*@
        <MudButton Variant="Variant.Filled" Color="Color.Primary">Login</MudButton> 
        
        <MudButton Variant="Variant.Filled" Color="Color.Secondary">Sign Up</MudButton>
        
    </MudAppBar> 
    <MudDrawer @bind-Open="@_drawerOpen" Elevation="24" Anchor="Anchor.Left">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">
                Header
            </MudText>
        </MudDrawerHeader>
        <MudDrawerContainer>
            <NavMenu />
        </MudDrawerContainer>
    </MudDrawer>
    
    <MudMainContent>
        @Body 
    </MudMainContent>

        <article class="content px-4">
            @Body
        </article>
    </main>

    <MudThemeProvider />
    <MudPopoverProvider />

    <!-- 2. Ensure interactivity is enabled -->
    <MudDialogProvider @rendermode="InteractiveServer" />
    <MudSnackbarProvider />
</div>



</MudLayout>

@code {
    bool _drawerOpen = false;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
