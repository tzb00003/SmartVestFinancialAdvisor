@using SmartVestFinancialAdvisor.Components.Services
@inject IAuthenticationService AuthService
@inherits LayoutComponentBase
@using MudBlazor
@inject IDialogService DialogService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (_isRestoring)
            {
                <span>Loading...</span>
            }
            else if (!AuthService.IsLoggedIn)
            {
                <a @onclick="OpenTestDialog" style="cursor:pointer">Sign In</a>
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 16px;">
                    <span>@AuthService.CurrentEmail</span>
                    <a @onclick="LogoutAsync" style="cursor:pointer; color: red;">Logout</a>
                </div>
            }
        </div>

        <article class="content px-4">
            @if (_isRestoring)
            {
                <div style="text-align: center; padding: 40px;">
                    <p>Loading your session...</p>
                </div>
            }
            else
            {
                @Body
            }
        </article>
    </main>

    <MudThemeProvider />
    <MudPopoverProvider />

    <MudDialogProvider @rendermode="InteractiveServer" />
    <MudSnackbarProvider />
</div>

@code {
    private bool _isRestoring = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isRestoring = true;
            await AuthService.RestoreSessionAsync();
        }
        finally
        {
            _isRestoring = false;
        }
    }

    private async Task OpenTestDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<LogInDialog>("Sign In", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
        }
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        StateHasChanged();
    }
}